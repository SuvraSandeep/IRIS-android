#:kivy 2.2.1

#:set BG        (0.039, 0.039, 0.039, 1)
#:set SURFACE   (0.059, 0.059, 0.059, 1)
#:set CYAN      (0, 1, 1, 1)
#:set CYAN_DIM  (0, 1, 1, 0.65)
#:set CYAN_MUT  (0, 1, 1, 0.35)
#:set FAINT     (0.22, 0.22, 0.22, 1)
#:set BORDER    (0, 1, 1, 0.07)

<IRISRoot>:
    orientation: 'vertical'
    canvas.before:
        Color:
            rgba: BG
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        size_hint_y: None
        height: dp(48)
        padding: [dp(16), dp(8)]
        spacing: dp(8)
        canvas.before:
            Color:
                rgba: BORDER
            Line:
                points: [self.x, self.y, self.x + self.width, self.y]
                width: 1

        BoxLayout:
            orientation: 'vertical'
            size_hint_x: None
            width: dp(100)
            spacing: dp(1)
            Label:
                text: 'IRIS'
                font_name: 'RobotoMono'
                font_size: dp(15)
                bold: True
                color: CYAN
                halign: 'left'
                valign: 'bottom'
                text_size: self.size
            Label:
                text: '// CORE v0.1'
                font_name: 'RobotoMono'
                font_size: dp(9)
                color: (1,1,1,0.18)
                halign: 'left'
                valign: 'top'
                text_size: self.size

        Widget:

        Label:
            id: status_label
            text: root.status_text
            font_name: 'RobotoMono'
            font_size: dp(9)
            color: CYAN_DIM
            size_hint_x: None
            width: dp(90)
            halign: 'right'
            text_size: self.size

        Widget:
            id: mic_dot
            size_hint_x: None
            width: dp(20)
            canvas:
                Color:
                    rgba: FAINT
                Ellipse:
                    pos: (self.center_x - dp(4), self.center_y - dp(4))
                    size: (dp(8), dp(8))

    ScreenManager:
        id: sm
        size_hint_y: 1
        MainScreen:
            name: 'main'
        AnalyticsScreen:
            name: 'analytics'
        DebugScreen:
            name: 'debug'

    BoxLayout:
        size_hint_y: None
        height: dp(56)
        padding: [dp(16), dp(8)]
        spacing: dp(12)
        canvas.before:
            Color:
                rgba: BORDER
            Line:
                points: [self.x, self.y + self.height, self.x + self.width, self.y + self.height]
                width: 1

        BoxLayout:
            spacing: dp(10)
            size_hint_x: 1
            Switch:
                id: sys_switch
                size_hint_x: None
                width: dp(60)
                active: False
                on_active: root.toggle_system(self.active)
            Label:
                text: root.toggle_label
                font_name: 'RobotoMono'
                font_size: dp(11)
                color: CYAN if root.is_active else FAINT
                halign: 'left'
                text_size: self.size

        BoxLayout:
            size_hint_x: None
            width: dp(130)
            spacing: dp(5)
            Button:
                text: 'SYS'
                font_name: 'RobotoMono'
                font_size: dp(9)
                background_color: (0,0,0,0)
                color: CYAN_MUT if root.ids.sm.current == 'main' else FAINT
                on_release: root.ids.sm.current = 'main'
            Button:
                text: 'STAT'
                font_name: 'RobotoMono'
                font_size: dp(9)
                background_color: (0,0,0,0)
                color: CYAN_MUT if root.ids.sm.current == 'analytics' else FAINT
                on_release: root.ids.sm.current = 'analytics'
            Button:
                text: 'DBG'
                font_name: 'RobotoMono'
                font_size: dp(9)
                background_color: (0,0,0,0)
                color: CYAN_MUT if root.ids.sm.current == 'debug' else FAINT
                on_release: root.ids.sm.current = 'debug'


<MainScreen>:
    canvas.before:
        Color:
            rgba: (0.039, 0.039, 0.039, 1)
        Rectangle:
            pos: self.pos
            size: self.size

    ScrollView:
        BoxLayout:
            orientation: 'vertical'
            size_hint_y: None
            height: self.minimum_height
            padding: [dp(12), dp(12)]
            spacing: dp(8)

            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: dp(160)
                spacing: dp(8)
                Widget:
                    size_hint_y: 1
                    canvas:
                        Color:
                            rgba: (0,1,1,0.06)
                        Ellipse:
                            pos: (self.center_x - dp(65), self.center_y - dp(65))
                            size: (dp(130), dp(130))
                        Color:
                            rgba: (0,1,1,0.1)
                        Ellipse:
                            pos: (self.center_x - dp(50), self.center_y - dp(50))
                            size: (dp(100), dp(100))
                        Color:
                            rgba: (0,1,1,0.15)
                        Ellipse:
                            pos: (self.center_x - dp(36), self.center_y - dp(36))
                            size: (dp(72), dp(72))
                        Color:
                            rgba: (0,1,1,0.2)
                        Ellipse:
                            pos: (self.center_x - dp(16), self.center_y - dp(16))
                            size: (dp(32), dp(32))
                Label:
                    id: subtitle_label
                    text: root.subtitle_text
                    font_name: 'RobotoMono'
                    font_size: dp(11)
                    color: (0,1,1,0.65)
                    size_hint_y: None
                    height: dp(20)
                    halign: 'center'
                    text_size: self.size

            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: dp(210)
                padding: dp(10)
                spacing: dp(6)
                canvas.before:
                    Color:
                        rgba: (0.059,0.059,0.059,1)
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [6]
                    Color:
                        rgba: (0,1,1,0.07)
                    Line:
                        rounded_rectangle: [self.x, self.y, self.width, self.height, 6]
                        width: 1
                Label:
                    text: 'CMD LOG'
                    font_name: 'RobotoMono'
                    font_size: dp(9)
                    color: (0.22,0.22,0.22,1)
                    size_hint_y: None
                    height: dp(16)
                    halign: 'left'
                    text_size: self.size
                ScrollView:
                    id: log_scroll
                    BoxLayout:
                        id: log_list
                        orientation: 'vertical'
                        size_hint_y: None
                        height: self.minimum_height
                        spacing: dp(6)
                        Label:
                            text: '[color=3a3a3a]boot[/color]  [color=00ffff]IRIS: System ready.[/color]'
                            markup: True
                            font_name: 'RobotoMono'
                            font_size: dp(10)
                            size_hint_y: None
                            height: self.texture_size[1]
                            halign: 'left'
                            text_size: (self.width, None)

            GridLayout:
                cols: 2
                size_hint_y: None
                height: dp(120)
                padding: dp(10)
                spacing: [dp(12), dp(6)]
                canvas.before:
                    Color:
                        rgba: (0.059,0.059,0.059,1)
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [6]
                    Color:
                        rgba: (0,1,1,0.07)
                    Line:
                        rounded_rectangle: [self.x, self.y, self.width, self.height, 6]
                        width: 1
                Label:
                    text: 'ENGINE'
                    font_name: 'RobotoMono'
                    font_size: dp(9)
                    color: (0.22,0.22,0.22,1)
                    halign: 'left'
                    text_size: self.size
                Label:
                    text: 'Vosk'
                    font_name: 'RobotoMono'
                    font_size: dp(10)
                    color: (0,1,1,1)
                    halign: 'right'
                    text_size: self.size
                Label:
                    text: 'CMDS'
                    font_name: 'RobotoMono'
                    font_size: dp(9)
                    color: (0.22,0.22,0.22,1)
                    halign: 'left'
                    text_size: self.size
                Label:
                    id: cmd_count_label
                    text: '0'
                    font_name: 'RobotoMono'
                    font_size: dp(10)
                    color: (0,1,1,1)
                    halign: 'right'
                    text_size: self.size
                Label:
                    text: 'UPTIME'
                    font_name: 'RobotoMono'
                    font_size: dp(9)
                    color: (0.22,0.22,0.22,1)
                    halign: 'left'
                    text_size: self.size
                Label:
                    id: uptime_label
                    text: '00:00'
                    font_name: 'RobotoMono'
                    font_size: dp(10)
                    color: (0,1,1,1)
                    halign: 'right'
                    text_size: self.size
                Label:
                    text: 'LATENCY'
                    font_name: 'RobotoMono'
                    font_size: dp(9)
                    color: (0.22,0.22,0.22,1)
                    halign: 'left'
                    text_size: self.size
                Label:
                    id: latency_label
                    text: '-'
                    font_name: 'RobotoMono'
                    font_size: dp(10)
                    color: (0,1,1,1)
                    halign: 'right'
                    text_size: self.size

            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: dp(90)
                spacing: dp(6)
                Label:
                    text: 'QUICK ACTIONS'
                    font_name: 'RobotoMono'
                    font_size: dp(9)
                    color: (0.22,0.22,0.22,1)
                    size_hint_y: None
                    height: dp(14)
                    halign: 'left'
                    text_size: self.size
                GridLayout:
                    cols: 6
                    spacing: dp(6)
                    Button:
                        text: 'YT'
                        font_name: 'RobotoMono'
                        font_size: dp(9)
                        background_color: (0.059,0.059,0.059,1)
                        color: (0,1,1,0.6)
                        on_release: root.quick_action('open youtube')
                    Button:
                        text: 'CALL'
                        font_name: 'RobotoMono'
                        font_size: dp(9)
                        background_color: (0.059,0.059,0.059,1)
                        color: (0,1,1,0.6)
                        on_release: root.quick_action('call contact')
                    Button:
                        text: 'BAT'
                        font_name: 'RobotoMono'
                        font_size: dp(9)
                        background_color: (0.059,0.059,0.059,1)
                        color: (0,1,1,0.35)
                        on_release: root.quick_action('battery status')
                    Button:
                        text: 'MSG'
                        font_name: 'RobotoMono'
                        font_size: dp(9)
                        background_color: (0.059,0.059,0.059,1)
                        color: (0,1,1,0.35)
                        on_release: root.quick_action('read messages')
                    Button:
                        text: 'MAP'
                        font_name: 'RobotoMono'
                        font_size: dp(9)
                        background_color: (0.059,0.059,0.059,1)
                        color: (0,1,1,0.35)
                        on_release: root.quick_action('open maps')
                    Button:
                        text: 'ALM'
                        font_name: 'RobotoMono'
                        font_size: dp(9)
                        background_color: (0.059,0.059,0.059,1)
                        color: (0,1,1,0.35)
                        on_release: root.quick_action('set alarm')


<AnalyticsScreen>:
    canvas.before:
        Color:
            rgba: (0.039, 0.039, 0.039, 1)
        Rectangle:
            pos: self.pos
            size: self.size
    BoxLayout:
        orientation: 'vertical'
        padding: dp(12)
        spacing: dp(10)
        Label:
            text: 'ANALYTICS - SESSION'
            font_name: 'RobotoMono'
            font_size: dp(10)
            color: (0.22,0.22,0.22,1)
            size_hint_y: None
            height: dp(20)
            halign: 'left'
            text_size: self.size
        GridLayout:
            cols: 2
            size_hint_y: None
            height: dp(110)
            spacing: dp(8)
            BoxLayout:
                canvas.before:
                    Color:
                        rgba: (0.059,0.059,0.059,1)
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [6]
                padding: dp(10)
                orientation: 'vertical'
                Label:
                    text: 'TOTAL CMDS'
                    font_name: 'RobotoMono'
                    font_size: dp(9)
                    color: (0.22,0.22,0.22,1)
                    halign: 'left'
                    text_size: self.size
                Label:
                    id: a_total
                    text: '0'
                    font_name: 'RobotoMono'
                    font_size: dp(22)
                    color: (0,1,1,1)
                    halign: 'left'
                    text_size: self.size
            BoxLayout:
                canvas.before:
                    Color:
                        rgba: (0.059,0.059,0.059,1)
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [6]
                padding: dp(10)
                orientation: 'vertical'
                Label:
                    text: 'SUCCESS RATE'
                    font_name: 'RobotoMono'
                    font_size: dp(9)
                    color: (0.22,0.22,0.22,1)
                    halign: 'left'
                    text_size: self.size
                Label:
                    id: a_rate
                    text: '0%'
                    font_name: 'RobotoMono'
                    font_size: dp(22)
                    color: (0,1,1,1)
                    halign: 'left'
                    text_size: self.size
        Label:
            text: 'No command data yet.'
            font_name: 'RobotoMono'
            font_size: dp(10)
            color: (0.22,0.22,0.22,1)
            halign: 'center'
            text_size: self.size


<DebugScreen>:
    canvas.before:
        Color:
            rgba: (0.027, 0.027, 0.027, 1)
        Rectangle:
            pos: self.pos
            size: self.size
    BoxLayout:
        orientation: 'vertical'
        padding: dp(14)
        spacing: dp(12)
        Label:
            text: '** RESTRICTED ACCESS **\nEnter passphrase to continue.'
            font_name: 'RobotoMono'
            font_size: dp(10)
            color: (0.22,0.22,0.22,1)
            size_hint_y: None
            height: dp(40)
            halign: 'center'
            text_size: self.size
        BoxLayout:
            size_hint_y: None
            height: dp(40)
            spacing: dp(8)
            TextInput:
                id: debug_pw
                hint_text: 'passphrase'
                font_name: 'RobotoMono'
                font_size: dp(13)
                password: True
                multiline: False
                background_color: (0.059,0.059,0.059,1)
                foreground_color: (0,1,1,1)
                cursor_color: (0,1,1,1)
                on_text_validate: root.try_debug_unlock(self.text)
            Button:
                text: 'EXEC'
                font_name: 'RobotoMono'
                font_size: dp(10)
                size_hint_x: None
                width: dp(60)
                background_color: (0.059,0.059,0.059,1)
                color: (0,1,1,0.6)
                on_release: root.try_debug_unlock(debug_pw.text)
        Label:
            id: debug_msg
            text: ''
            font_name: 'RobotoMono'
            font_size: dp(10)
            color: (1,0.231,0.231,0.7)
            size_hint_y: None
            height: dp(20)
            halign: 'center'
            text_size: self.size
